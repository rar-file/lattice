# Lattice — environment variables (prefix: LATTICE_)
# Copy to .env for local dev. Never commit a real .env.
#
# Lattice runs ENTIRELY OFFLINE by default. No AI key is required to open
# a vault, search, capture, browse, or expose the vault via MCP. The
# variables below are only relevant if you (a) deploy in cloud mode or
# (b) want optional cloud-LLM features later.

# local | cloud
LATTICE_MODE=local

# --- Local mode -------------------------------------------------------------
# Where Lattice persists its SQLite DB + per-launch token. Defaults to
# ~/.lattice. Override if you want to keep state under a custom path.
# LATTICE_LOCAL_DATA_DIR=/root/.lattice

# Embeddings run locally via fastembed (no key, no network after the first
# model download). Default model is BAAI/bge-small-en-v1.5 (~120 MB).
LATTICE_EMBEDDING_PROVIDER=fastembed
LATTICE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Cloud mode (only relevant when LATTICE_MODE=cloud) ---------------------
LATTICE_CLOUD_DATABASE_URL=postgresql+asyncpg://lattice:lattice@localhost:5432/lattice
LATTICE_CLOUD_SESSION_SECRET=change-me-in-prod

# --- Optional ---------------------------------------------------------------
# Lattice itself does not call any cloud LLM in v1. External AI tools talk
# to your vault through Lattice's MCP server (`lattice mcp serve`) and use
# THEIR OWN keys — Claude Desktop, Cursor, etc. The Anthropic key below is
# only consumed by future opt-in features (capture reshape, weekly
# synthesis) and is safe to leave unset.
# LATTICE_ANTHROPIC_API_KEY=sk-ant-...
