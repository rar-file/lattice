{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "**/.next",
      "**/.turbo",
      "**/node_modules",
      "**/dist",
      "**/build",
      "**/target",
      "**/out",
      "**/src-tauri/gen",
      "**/.venv",
      "**/__pycache__",
      "**/.pyinstaller",
      "**/.claude",
      "**/.pytest_cache",
      "**/.ruff_cache",
      "**/pnpm-lock.yaml",
      "**/uv.lock"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true }
  },
  "overrides": [
    {
      "include": ["**/icons.tsx", "**/TopBar.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "noSvgWithoutTitle": "off"
          }
        }
      }
    },
    {
      "include": ["**/app/**/*.tsx", "**/components/**/*.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "noAutofocus": "off",
            "noLabelWithoutControl": "off",
            "useKeyWithClickEvents": "off",
            "useSemanticElements": "off"
          }
        }
      }
    }
  ],
  "organizeImports": { "enabled": true }
}
